---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Projects">
  <Nav />
  <main>
    <div class="container">
      <header class="page-header">
        <h1>Projects</h1>
        <p class="faint">Tools, experiments, and things I've shipped.</p>
      </header>

      {projects.length > 0 ? (
        <ul class="project-list">
          {projects.map((project) => (
            <li class="project-entry">
              <div class="project-row">
                <a
                  href={project.data.url ?? `/projects/${project.slug}`}
                  class="project-title"
                  target={project.data.url ? '_blank' : undefined}
                  rel={project.data.url ? 'noopener' : undefined}
                >
                  {project.data.title}
                </a>
                <span class:list={['project-status mono', project.data.status]}>
                  {project.data.status}
                </span>
              </div>
              <p class="project-desc faint">{project.data.description}</p>
              {project.data.tags.length > 0 && (
                <div class="tags">
                  {project.data.tags.map(tag => (
                    <span class="tag mono">{tag}</span>
                  ))}
                </div>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <p class="faint mono" style="font-size: 0.85rem; padding: 3rem 0;">— forthcoming —</p>
      )}
    </div>
  </main>
  <Footer />
</Base>

<style>
  .page-header {
    padding: clamp(2.5rem, 6vw, 5rem) 0 2rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 0.5rem;
  }

  .project-list { list-style: none; }

  .project-entry {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .project-entry:first-child { border-top: 1px solid var(--rule); }

  .project-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  .project-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    text-decoration: none;
    transition: color 0.15s;
  }

  .project-title:hover { color: var(--accent); }

  .project-status {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .project-status.active { color: var(--accent); }
  .project-status.shipped { color: var(--accent-cool); }
  .project-status.archived { color: var(--ink-ghost); }

  .project-desc {
    font-size: 0.9rem;
    max-width: 60ch;
    margin-bottom: 0.75rem;
  }

  .tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  .tag {
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    padding: 0.15em 0.5em;
    border: 1px solid var(--rule);
    color: var(--ink-faint);
  }
</style>
